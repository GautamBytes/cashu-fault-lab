# Cashu Fault Lab — local development environment
# Copy this file to .env.local and FILL IN YOUR OWN VALUES before use.
# WARNING: The values below are example placeholder tokens ONLY.
# Do NOT use them in any non-local environment — they are guessable.
# Do NOT commit .env or .env.local — they are git-ignored.

# --- Cashu-ts adapter (loopback, port 4101) ---
CFL_CASHU_TS_TOKEN=lab-only-cashu-ts-token
CFL_CASHU_TS_CLAIM_KEY=ERERERERERERERERERERERERERERERERERERERERERE
# CFL_CASHU_TS_PAYMENT_TARGET=http://127.0.0.1:4101/pay
# CFL_CASHU_TS_NOSTR_SENDER_KEY=ERERERERERERERERERERERERERERERERERERERERERE
# CFL_CASHU_TS_NOSTR_RECEIVER_KEY=IiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiIiI
# CFL_CASHU_TS_NOSTR_RELAYS=ws://127.0.0.1:4400
# CFL_NOSTR_FAULT_RELAY_PORT=4400
# CFL_CASHU_TS_RECEIVER_DATABASE_URL=postgresql://cashu:cashu-local-development-only@127.0.0.1:5432/cashu_fault_lab
# CFL_CASHU_TS_RECEIVER_STATE_KEY=BwcHBwcHBwcHBwcHBwcHBwcHBwcHBwcHBwcHBwcHBwc
# CFL_CASHU_TS_RECEIVER_TENANT_ID=cashu-ts-local
# CFL_POSTGRES_PASSWORD=cashu-local-development-only

# --- CDK Rust adapter (loopback, port 4102) ---
CFL_CDK_TOKEN=lab-only-cdk-token

# --- Reference receiver (loopback, port 4200) ---
CFL_REFERENCE_RECEIVER_TOKEN=lab-only-receiver-token
CFL_REFERENCE_RECEIVER_CLAIM_KEY=ERERERERERERERERERERERERERERERERERERERERERE

# --- HTTP fault gateway (loopback, port 4300) ---
CFL_HTTP_FAULT_GATEWAY_TOKEN=lab-only-fault-token
CFL_HTTP_FAULT_GATEWAY_URL=http://127.0.0.1:4300

# --- Docker compose port overrides (optional) ---
# CFL_NUTSHELL_PORT=3338
# CFL_CASHU_TS_PORT=4101
# CFL_CDK_ADAPTER_PORT=4102
# CFL_REFERENCE_RECEIVER_PORT=4200
# CFL_HTTP_FAULT_GATEWAY_PORT=4300

# --- Wallet funding amount in sats (optional) ---
# CFL_WALLET_FUNDING_AMOUNT=64

# --- Real mint URLs for funded lanes (optional) ---
# CFL_REAL_MINT_URL=http://127.0.0.1:3338
