{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cashu-fault-lab.dev/schema/adapter-capabilities-v1.json",
  "title": "Cashu Fault Lab Adapter Capabilities",
  "type": "object",
  "additionalProperties": false,
  "required": ["implementation", "version", "nuts", "transports", "evidenceTier"],
  "properties": {
    "implementation": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "nuts": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "integer", "minimum": 0 }
    },
    "transports": {
      "type": "array",
      "uniqueItems": true,
      "items": { "enum": ["http", "nostr"] }
    },
    "evidenceTier": { "enum": ["T0", "T1", "T2", "T3"] },
    "encodings": {
      "type": "array",
      "uniqueItems": true,
      "items": { "enum": ["creqA", "creqB"] }
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "roles", "status"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "roles": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "enum": ["sender", "receiver"] }
          },
          "status": { "enum": ["supported", "unsupported"] },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
