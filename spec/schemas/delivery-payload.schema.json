{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cashu-fault-lab.dev/schema/delivery-payload-v1.json",
  "title": "Cashu Delivery V1 Payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "mint", "unit", "proofs", "delivery"],
  "properties": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{21}[AQgw]$" },
    "memo": { "type": ["string", "null"] },
    "mint": { "type": "string", "minLength": 1, "format": "cashu-mint-url" },
    "unit": { "type": "string", "minLength": 1 },
    "proofs": {
      "type": "array",
      "maxItems": 256,
      "items": { "$ref": "#/$defs/proof" }
    },
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["v", "id", "created_at", "expires_at"],
      "properties": {
        "v": { "const": 1 },
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{21}[AQgw]$" },
        "created_at": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "expires_at": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
      }
    }
  },
  "$defs": {
    "proof": {
      "type": "object",
      "required": ["amount", "id", "secret", "C"],
      "properties": {
        "amount": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "id": { "type": "string", "minLength": 1 },
        "secret": { "type": "string", "minLength": 1 },
        "C": { "type": "string", "minLength": 1 },
        "witness": { "type": "string" },
        "dleq": { "type": "object" }
      }
    }
  }
}
