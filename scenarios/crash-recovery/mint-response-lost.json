{
  "name": "crash-recovery-mint-response-lost",
  "description": "Mint commits the swap but drops the response. Receiver restarts, recovers via NUT-19 replay or NUT-09 restore, and settles without double credit.",
  "commands": [
    {
      "type": "configure_fault",
      "target": "mint",
      "rule": { "kind": "timeout_after_commit", "occurrence": 1 }
    },
    { "type": "send", "sender": "reference", "requestId": "AAECAwQFBgcICQoLDA0ODw" },
    { "type": "restart", "component": "receiver" },
    { "type": "clear_faults", "target": "mint" },
    { "type": "send", "sender": "reference", "requestId": "AAECAwQFBgcICQoLDA0ODw" },
    { "type": "assert_quiescent" }
  ]
}
